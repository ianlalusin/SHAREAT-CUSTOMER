{
  "entities": {
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer using the SharEat Customer Hub.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Table": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Table",
      "type": "object",
      "description": "Represents a physical dining table.",
      "properties": {
        "id": { "type": "string" },
        "tableNumber": { "type": "string" },
        "section": { "type": "string" }
      },
      "required": ["id", "tableNumber"]
    },
    "MenuItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MenuItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      }
    },
    "CustomerPin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CustomerPin",
      "type": "object",
      "description": "Mapping of 6-digit PINs to active store sessions.",
      "properties": {
        "pin": { "type": "string" },
        "storeId": { "type": "string" },
        "sessionId": { "type": "string" },
        "tableId": { "type": "string" },
        "customerName": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/catalogItems/{itemId}",
        "definition": {
          "entityName": "MenuItem",
          "description": "Public menu items available for viewing."
        }
      },
      {
        "path": "/customerPins/{pin}",
        "definition": {
          "entityName": "CustomerPin",
          "description": "PIN registry for customer login."
        }
      },
      {
        "path": "/refillRequests/{requestId}",
        "definition": {
          "entityName": "Request",
          "description": "Customer-initiated refill and service requests."
        }
      }
    ]
  }
}